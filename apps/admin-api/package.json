{
  "name": "@ffp/admin-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node-pg-migrate -m migrations -j ts -t pgmigrations --tsconfig tsconfig.migrate.json"
  },
  "dependencies": {
    "@ffp/shared-types": "workspace:*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
