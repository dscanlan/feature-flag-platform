PORT=4000
LOG_LEVEL=info
NODE_ENV=development

DATABASE_URL=postgres://flags:flags@localhost:5433/flags
REDIS_URL=redis://localhost:6380

# Run migrations on boot (dev convenience).
MIGRATE_ON_BOOT=true

# Seeded admin user. Leave ADMIN_PASSWORD blank in prod and seed via migrations job.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Cookie signing secret. Generate with: openssl rand -hex 32
COOKIE_SECRET=replace-me-with-32-bytes-of-hex
